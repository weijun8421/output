@echo off
set "_ps=%TEMP%\~dcv3_%RANDOM%.ps1"
powershell -ExecutionPolicy Bypass -NoProfile -Command "$b=Get-Content '%~f0' -Raw; $start=($b.IndexOf('#PS'+'_ENC_BEGIN#')+15); $end=$b.IndexOf('#PS'+'_ENC_END#'); $code=[Text.Encoding]::Unicode.GetString([Convert]::FromBase64String($b.Substring($start,$end-$start).Trim())); [IO.File]::WriteAllText($env:_ps,$code)"
powershell -ExecutionPolicy Bypass -NoProfile -File "%_ps%" %*
set "_exitcode=%ERRORLEVEL%"
del "%_ps%" 2>nul
pause
exit /b %_exitcode%
#PS_ENC_BEGIN#

#PS_ENC_END#
